{
  "name": "px-diff",
  "version": "0.1.0",
  "description": "Visual pixel-by-pixel comparison of web pages using Playwright",
  "type": "module",
  "bin": {
    "px-diff": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "start": "bun src/cli.ts"
  },
  "dependencies": {
    "pixelmatch": "^7.2.0",
    "playwright": "^1.61.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.0.0",
    "@types/pngjs": "^6.0.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
